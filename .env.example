SMS_PROVIDER=twilio
SMS_DEFAULT_COUNTRY_CODE=+91
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+12345678900

# For Render or any hosted Postgres database:
# DATABASE_URL=postgresql://username:password@host:5432/database_name

# For persistent SQLite on a mounted disk:
# HOSPITAL_KIOSK_DB_PATH=/var/data/hospital_kiosk.db

# One-time migration helper:
# SOURCE_SQLITE_PATH=/absolute/path/to/hospital/instance/hospital_kiosk.db

# Use TextBee instead of Twilio:
# SMS_PROVIDER=textbee
# TEXTBEE_API_KEY=your_textbee_api_key
# TEXTBEE_DEVICE_ID=your_textbee_device_id
